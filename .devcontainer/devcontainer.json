{
    "name": "DevContainer for Haskell",
    "remoteUser": "vscode",
    "runArgs": [],
    "build": {
      "args": {
      },
      "context": "..",
      "dockerfile": "Dockerfile"
    },
    "customizations": {
      "vscode": {
        "extensions": [
            "haskell.haskell"
        ],
        "settings": {
          "files.exclude": {
            "**/*.olean": true,
            "**/.DS_Store": true,
            "**/.git": true,
            "**/.hg": true,
            "**/.svn": true,
            "**/CVS": true
          }
        }
      }
    }
  }